{
  "_comment": "Bu şablon tüm ortamlar için temel key yapısını gösterir. Her ortam için değerler değiştirilmelidir.",

  "ConnectionStrings": {
    "MainConnectionString": "[DB_CONNECTION_STRING]"
  },
  "StartupConfigs": {
    "ProjectPrefix": "[VM_PROJECT_PREFIX]",
    "Policy": "[CORS_POLICY_NAME]",
    "ApiUrl": "[API_BASE_URL]",
    "MigrationAssembly": "[MIGRATION_ASSEMBLY_NAME]",
    "AllowAnonymous": false,
    "ApiName": "[API_NAME]"
  },
  "RabbitMqSettings": {
    "HostName": "[RABBITMQ_HOST]",
    "PortNumber": "[RABBITMQ_PORT]",
    "UserName": "[RABBITMQ_USER]",
    "Password": "[PASSWORD]",
    "VirtualHost": "[RABBITMQ_VHOST]"
  },
  "OcppSettings": {
    "WebSocketPath": "/ocpp",
    "WebSocketPort": "[OCPP_WS_PORT]",
    "HeartbeatIntervalSeconds": "[OCPP_HEARTBEAT_INTERVAL]",
    "ConnectionTimeoutSeconds": "[OCPP_CONNECTION_TIMEOUT]",
    "MaxConnections": "[OCPP_MAX_CONNECTIONS]"
  },
  "JwtSettings": {
    "SecretKey": "[TOKEN_SECRET_KEY]",
    "Issuer": "[JWT_ISSUER]",
    "Audience": "[JWT_AUDIENCE]",
    "ExpiryMinutes": "[JWT_EXPIRY_MINUTES]",
    "RefreshTokenExpiryDays": "[REFRESH_TOKEN_EXPIRY_DAYS]"
  },
  "Wallet": {
    "TockenKey": "[TOKEN_SECRET_KEY]"
  },
  "VmApiSettings": {
    "BaseUrl": "[VM_API_URL]"
  },
  "VmPanelApiSettings": {
    "BaseUrl": "[VM_PANEL_API_URL]"
  },
  "SignalRSettings": {
    "HubPath": "/vmHub"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",

  "_environments": {
    "_dev": {
      "ConnectionStrings_MainConnectionString": "Server=localhost;Database=VmDb_Dev;...",
      "RabbitMqSettings_HostName": "localhost",
      "Logging_LogLevel_Default": "Debug"
    },
    "_local": {
      "ConnectionStrings_MainConnectionString": "Server=localhost;Database=VmDb_Local;...",
      "RabbitMqSettings_HostName": "localhost",
      "Logging_LogLevel_Default": "Information"
    },
    "_test": {
      "ConnectionStrings_MainConnectionString": "Server=[TEST_SERVER];Database=VmDb_Test;...",
      "RabbitMqSettings_HostName": "[TEST_RABBITMQ_HOST]",
      "Logging_LogLevel_Default": "Information"
    },
    "_prod": {
      "ConnectionStrings_MainConnectionString": "Server=[PROD_SERVER];Database=VmDb;...",
      "RabbitMqSettings_HostName": "[PROD_RABBITMQ_HOST]",
      "Logging_LogLevel_Default": "Warning"
    }
  }
}
