{
  "ConnectionStrings": {
    "MainConnectionString": "[DB_CONNECTION_STRING]"
  },
  "MobilApi": {
    "Url": "[MOBIL_API_URL]",
    "BaseUrl": "[MOBIL_API_BASE_URL]"
  },
  "NotificationApi": {
    "Url": "[NOTIFICATION_API_URL]"
  },
  "StationApi": {
    "Url": "[STATION_API_URL]"
  },
  "IntegrationApi": {
    "Url": "[INTEGRATION_API_URL]"
  },
  "StartupConfigs": {
    "ProjectPrefix": "[SARJPRO_PROJECT_PREFIX]",
    "Policy": "[CORS_POLICY_NAME]",
    "ApiUrl": "[API_BASE_URL]",
    "MigrationAssembly": "[MIGRATION_ASSEMBLY_NAME]",
    "AllowAnonymous": false,
    "ApiName": "[API_NAME]"
  },
  "RabbitMqSettings": {
    "HostName": "[RABBITMQ_HOST]",
    "PortNumber": "[RABBITMQ_PORT]",
    "UserName": "[SARJPRO_RABBITMQ_USER]",
    "Password": "[SARJPRO_RABBITMQ_PASSWORD]",
    "VirtualHost": "[SARJPRO_RABBITMQ_VHOST]"
  },
  "PaymentIntegrations": [
    {
      "Name": "IYZICO",
      "Selected": false
    },
    {
      "Name": "PARAM",
      "Selected": false
    },
    {
      "Name": "MOKA",
      "Selected": true
    }
  ],
  "MokaSettings": {
    "DealerCode": "[MOKA_DEALER_CODE]",
    "Username": "[MOKA_USERNAME]",
    "Password": "[MOKA_PASSWORD]",
    "BaseUrl": "[MOKA_API_BASE_URL]"
  },
  "IyzicoSettings": {
    "ApiKey": "[IYZICO_API_KEY]",
    "SecretKey": "[IYZICO_SECRET_KEY]",
    "BaseUrl": "[IYZICO_BASE_URL]"
  },
  "ParamSettings": {
    "ClientCode": "[PARAM_CLIENT_CODE]",
    "ClientUsername": "[PARAM_CLIENT_USERNAME]",
    "ClientPassword": "[PARAM_CLIENT_PASSWORD]"
  },
  "ParasutIntegration": {
    "BaseUrl": "[PARASUT_BASE_URL]",
    "ClientId": "[API_KEY]",
    "ClientSecret": "[API_SECRET]",
    "Username": "[PARASUT_USER]",
    "Password": "[PASSWORD]"
  },
  "InvoiceUsing": {
    "usingType": "[INVOICE_USING_TYPE]",
    "entegratorType": "[ENTEGRATOR_TYPE]"
  },
  "Wallet": {
    "TockenKey": "[TOKEN_SECRET_KEY]"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*"
}
