{
  "ConnectionStrings": {
    "DefaultConnection": "[DB_CONNECTION_STRING]"
  },
  "IoTSettings": {
    "Protocol": "[IOT_PROTOCOL]",
    "BrokerHost": "[IOT_BROKER_HOST]",
    "BrokerPort": "[IOT_BROKER_PORT]",
    "ClientId": "[IOT_CLIENT_ID]",
    "UserName": "[IOT_USERNAME]",
    "Password": "[IOT_PASSWORD]",
    "UseTls": false,
    "CommandTimeoutSeconds": "[IOT_COMMAND_TIMEOUT_SECONDS]",
    "ReconnectIntervalSeconds": "[IOT_RECONNECT_INTERVAL_SECONDS]"
  },
  "DeviceSettings": {
    "MaxDevicesPerRoom": "[MAX_DEVICES_PER_ROOM]",
    "DefaultCurtainSpeed": "[DEFAULT_CURTAIN_SPEED]",
    "StatusPollIntervalSeconds": "[STATUS_POLL_INTERVAL_SECONDS]"
  },
  "SignalRSettings": {
    "HubPath": "/deviceHub"
  },
  "SessionSettings": {
    "TimeoutMinutes": "[SESSION_TIMEOUT_MINUTES]",
    "CookieName": "[SESSION_COOKIE_NAME]"
  },
  "AdminCredentials": {
    "DefaultUsername": "[ADMIN_USERNAME]",
    "DefaultPasswordHash": "[ADMIN_PASSWORD_HASH]"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*"
}
