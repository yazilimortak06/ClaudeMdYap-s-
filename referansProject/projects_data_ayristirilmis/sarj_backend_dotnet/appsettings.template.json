{
  "ConnectionStrings": {
    "MainConnectionString": "[DB_CONNECTION_STRING]"
  },
  "MobilApi": {
    "Url": "[MOBIL_API_URL]",
    "BaseUrl": "[MOBIL_API_BASE_URL]"
  },
  "NotificationApi": {
    "Url": "[NOTIFICATION_API_URL]"
  },
  "StationApi": {
    "Url": "[STATION_API_URL]"
  },
  "IntegrationApi": {
    "Url": "[INTEGRATION_API_URL]"
  },
  "StartupConfigs": {
    "ProjectPrefix": "[PROJECT_PREFIX]",
    "Policy": "[CORS_POLICY_NAME]",
    "ApiUrl": "[API_BASE_URL]",
    "MigrationAssembly": "[MIGRATION_ASSEMBLY_NAME]",
    "AllowAnonymous": false,
    "ApiName": "[API_NAME]"
  },
  "RabbitMqSettings": {
    "HostName": "[RABBITMQ_HOST]",
    "PortNumber": "[RABBITMQ_PORT]",
    "UserName": "[RABBITMQ_USER]",
    "Password": "[PASSWORD]"
  },
  "PaymentIntegrations": [
    {
      "Name": "[PAYMENT_PROVIDER_1]",
      "Selected": false
    },
    {
      "Name": "[PAYMENT_PROVIDER_2]",
      "Selected": false
    },
    {
      "Name": "[PAYMENT_PROVIDER_3]",
      "Selected": true
    }
  ],
  "ParasutIntegration": {
    "BaseUrl": "[PARASUT_BASE_URL]",
    "ClientId": "[API_KEY]",
    "ClientSecret": "[API_SECRET]",
    "Username": "[PARASUT_USER]",
    "Password": "[PASSWORD]"
  },
  "InvoiceUsing": {
    "usingType": "[INVOICE_USING_TYPE]",
    "entegratorType": "[ENTEGRATOR_TYPE]"
  },
  "LogoEInvoiceIntegration": {
    "BaseUrl": "[LOGO_EINVOICE_URL]",
    "ApiKey": "[API_KEY]",
    "ApiSecret": "[API_SECRET]"
  },
  "LogoEArchiveIntegration": {
    "BaseUrl": "[LOGO_EARCHIVE_URL]",
    "ApiKey": "[API_KEY]",
    "ApiSecret": "[API_SECRET]"
  },
  "Wallet": {
    "TockenKey": "[TOKEN_SECRET_KEY]"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*"
}
