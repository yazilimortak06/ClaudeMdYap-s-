{
  "ConnectionStrings": {
    "MainConnectionString": "[DB_CONNECTION_STRING]"
  },
  "StartupConfigs": {
    "ProjectPrefix": "[PROJECT_PREFIX]",
    "Policy": "[CORS_POLICY_NAME]",
    "ApiUrl": "[CRM_API_BASE_URL]",
    "MigrationAssembly": "[MIGRATION_ASSEMBLY_NAME]",
    "AllowAnonymous": false,
    "ApiName": "CRM"
  },
  "RabbitMqSettings": {
    "HostName": "[RABBITMQ_HOST]",
    "PortNumber": "[RABBITMQ_PORT]",
    "UserName": "[RABBITMQ_USER]",
    "Password": "[PASSWORD]",
    "VirtualHost": "[RABBITMQ_VHOST]"
  },
  "MongoDbSettings": {
    "ConnectionString": "[MONGODB_CONNECTION_STRING]",
    "DatabaseName": "[MONGODB_DATABASE_NAME]",
    "LogCollectionName": "[MONGODB_LOG_COLLECTION]"
  },
  "JwtSettings": {
    "SecretKey": "[JWT_SECRET_KEY]",
    "Issuer": "[JWT_ISSUER]",
    "Audience": "[JWT_AUDIENCE]",
    "ExpiryMinutes": "[JWT_EXPIRY_MINUTES]",
    "RefreshTokenExpiryDays": "[REFRESH_TOKEN_EXPIRY_DAYS]"
  },
  "TokenServiceSettings": {
    "BaseUrl": "[TOKEN_SERVICE_URL]",
    "ApiKey": "[INTER_SERVICE_API_KEY]"
  },
  "FileServiceSettings": {
    "BaseUrl": "[FILE_SERVICE_URL]"
  },
  "SmtpSettings": {
    "Host": "[SMTP_HOST]",
    "Port": "[SMTP_PORT]",
    "UserName": "[SMTP_USER]",
    "Password": "[SMTP_PASSWORD]",
    "EnableSsl": true,
    "FromAddress": "[EMAIL_FROM_ADDRESS]",
    "FromName": "[EMAIL_FROM_NAME]"
  },
  "FileSettings": {
    "UploadPath": "[FILE_UPLOAD_PATH]",
    "AllowedExtensions": "[ALLOWED_FILE_EXTENSIONS]",
    "MaxFileSizeMB": "[MAX_FILE_SIZE_MB]"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*"
}
