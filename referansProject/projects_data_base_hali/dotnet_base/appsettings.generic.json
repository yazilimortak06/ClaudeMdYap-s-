{
  "ConnectionStrings": {
    "Default": "[DB_CONNECTION_STRING]"
  },
  "ServiceEndpoints": {
    "ServiceA": {
      "Url": "[SERVICE_A_URL]",
      "BaseUrl": "[SERVICE_A_BASE_URL]"
    },
    "ServiceB": {
      "Url": "[SERVICE_B_URL]"
    },
    "ServiceC": {
      "Url": "[SERVICE_C_URL]"
    }
  },
  "StartupConfigs": {
    "ProjectPrefix": "[PROJECT_PREFIX]",
    "CorsPolicy": "[CORS_POLICY_NAME]",
    "ApiBaseUrl": "[API_BASE_URL]",
    "MigrationAssembly": "[MIGRATION_ASSEMBLY_NAME]",
    "AllowAnonymous": false,
    "ServiceName": "[SERVICE_NAME]"
  },
  "MessageBus": {
    "HostName": "[MESSAGE_BUS_HOST]",
    "Port": "[MESSAGE_BUS_PORT]",
    "UserName": "[MESSAGE_BUS_USER]",
    "Password": "[PASSWORD]"
  },
  "PaymentProviders": [
    {
      "Name": "[PROVIDER_1]",
      "IsActive": false
    },
    {
      "Name": "[PROVIDER_2]",
      "IsActive": false
    },
    {
      "Name": "[PROVIDER_3]",
      "IsActive": true
    }
  ],
  "AccountingIntegration": {
    "BaseUrl": "[ACCOUNTING_API_URL]",
    "ClientId": "[API_KEY]",
    "ClientSecret": "[API_SECRET]",
    "Username": "[ACCOUNTING_USER]",
    "Password": "[PASSWORD]"
  },
  "InvoiceConfig": {
    "UsageType": "[INVOICE_USAGE_TYPE]",
    "IntegratorType": "[INTEGRATOR_TYPE]"
  },
  "EInvoiceIntegration": {
    "BaseUrl": "[EINVOICE_API_URL]",
    "ApiKey": "[API_KEY]",
    "ApiSecret": "[API_SECRET]"
  },
  "EArchiveIntegration": {
    "BaseUrl": "[EARCHIVE_API_URL]",
    "ApiKey": "[API_KEY]",
    "ApiSecret": "[API_SECRET]"
  },
  "Auth": {
    "SecretKey": "[TOKEN_SECRET_KEY]",
    "Issuer": "[TOKEN_ISSUER]",
    "Audience": "[TOKEN_AUDIENCE]",
    "ExpiryMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*"
}
