// Kaynak: E:\Projeler\Backend\RotaWattBackEnd\src\Presentation\Log.Api\appsettings.json
// NOT: Gerçek credentials maskelenmiştir. Ortam değişkeni veya secrets yöntemiyle inject edilmelidir.

{
  "ConnectionStrings": {
    "RotaWattConnectionString": "Server=<DB_HOST>;Database=<DB_NAME>;User Id=<DB_USER>;Password=<DB_PASSWORD>;Trusted_Connection=False;MultipleActiveResultSets=True;"
  },
  "StartupConfigs": {
    "ProjectPrefix": "Log",
    "Policy": "_myAllowSpecificOrigins",
    "ApiUrl": "https://localhost:<PORT>",
    "MigrationAssembly": "Log.Persistence",
    "AllowAnonymous": false,
    "ApiName": "Log"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "RabbitMqSettings": {
    "HostName": "<RABBITMQ_HOST>",
    "PortNumber": 5672,
    "UserName": "<RABBITMQ_USER>",
    "Password": "<RABBITMQ_PASSWORD>"
  },
  "AllowedHosts": "*"
}
